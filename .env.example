# ==========================================================
# QMUL Arcade — environment variables
# Copy to .env (local) or set in Railway > Variables (prod)
# ==========================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# SQLite file location. On Railway, attach a Volume mounted at /data.
DB_PATH=/data/app.db
# For local dev you can override to a folder you own:
# DB_PATH=./data/app.db

# Admin users (comma-separated Discord user IDs). Only these can trigger backup/restore/clear.
ADMIN_DISCORD_IDS=111111111111111111,222222222222222222

# Shared admin code. Anyone who enters this code via the in-app "Become admin" dialog
# gets admin privileges for their session. Leave empty to disable the claim flow.
ADMIN_CODE=change-me

# --- Discord Activity / OAuth ---
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
# URL the client will be served from (Railway public URL)
PUBLIC_URL=https://your-app.up.railway.app

# --- Client (Vite) ---
# Vite only exposes vars prefixed with VITE_
VITE_DISCORD_CLIENT_ID=your_client_id
VITE_API_BASE=/api
