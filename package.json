{
  "name": "qmul-arcade",
  "private": true,
  "version": "0.1.0",
  "description": "QMUL Arcade — a Discord Activity with Wordle, Gacha, Scribble, and a shared Whiteboard.",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace shared run build && npm --workspace client run build",
    "start": "npm --workspace server run start",
    "postinstall": "npm --workspace shared run build || true",
    "lint": "echo 'Add your linter of choice'"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
